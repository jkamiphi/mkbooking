# Database
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here"
BETTER_AUTH_URL="https://your-domain.onrender.com"
NEXT_PUBLIC_APP_URL="https://your-domain.onrender.com"

# Transactional Email (for password reset)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
AUTH_EMAIL_FROM="MK Booking <no-reply@your-domain.com>"

# AWS S3
AWS_REGION="us-east-1"
AWS_S3_BUCKET="mkbooking-assets"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_PUBLIC_BASE_URL="https://mkbooking-assets.s3.us-east-1.amazonaws.com"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
NEXT_PUBLIC_GOOGLE_MAP_ID="your-google-map-id"
