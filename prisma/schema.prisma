// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// BETTER AUTH MODELS
// ============================================================================

model user {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions session[]
  accounts account[]
  profile  UserProfile?

  @@map("user")
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ============================================================================
// USER PROFILE EXTENSION
// ============================================================================

// System-level roles for platform access control
enum SystemRole {
  SUPERADMIN // Full platform access
  STAFF // Platform employee with limited admin access
  DESIGNER // Design workflow role for order creatives and color proofs
  SALES // Commercial validation role for orders and requests
  OPERATIONS_PRINT // Final print workflow role
  INSTALLER // Installer role for field operational work orders
  CUSTOMER // Regular users (advertisers, agencies) - default

  @@map("system_role")
}

enum UserAccountType {
  DIRECT_CLIENT
  AGENCY

  @@map("user_account_type")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique

  // System Role (platform-level access)
  systemRole SystemRole @default(CUSTOMER)
  accountType UserAccountType @default(DIRECT_CLIENT)

  // Personal Information
  firstName String?
  lastName  String?
  phone     String?
  locale    String  @default("es-PA")
  timezone  String  @default("America/Panama")

  // Preferences
  emailNotifications    Boolean @default(true)
  whatsappNotifications Boolean @default(false)
  smsNotifications      Boolean @default(false)

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  // Audit Fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  // Relations
  user                     user                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationRoles        OrganizationMember[]
  createdOrganizations     Organization[]          @relation("OrganizationCreator")
  auditLogs                AuditLog[]              @relation("AuditLogActor")
  catalogHolds             CatalogHold[]           @relation("CatalogHoldCreator")
  createdCampaignRequests  CampaignRequest[]       @relation("CampaignRequestCreator")
  resolvedCampaignRequests CampaignRequest[]       @relation("CampaignRequestResolver")
  createdOrders            Order[]                 @relation("OrderCreator")
  confirmedOrders          Order[]                 @relation("OrderConfirmer")
  salesReviewedOrders      Order[]                 @relation("OrderSalesReviewer")
  uploadedCreatives        OrderCreative[]         @relation("CreativeUploader")
  reviewedCreatives        OrderCreative[]         @relation("CreativeReviewer")
  uploadedPurchaseOrders   OrderPurchaseOrder[]    @relation("PurchaseOrderUploader")
  reviewedPurchaseOrders   OrderPurchaseOrder[]    @relation("PurchaseOrderReviewer")
  salesReviewEvents        OrderSalesReviewEvent[] @relation("OrderSalesReviewEventActor")
  assignedOrderDesignTasks OrderDesignTask[]       @relation("OrderDesignTaskAssignee")
  createdOrderDesignTasks  OrderDesignTask[]       @relation("OrderDesignTaskCreator")
  orderDesignTaskEvents    OrderDesignTaskEvent[]  @relation("OrderDesignTaskEventActor")
  assignedOrderPrintTasks  OrderPrintTask[]        @relation("OrderPrintTaskAssignee")
  completedOrderPrintTasks OrderPrintTask[]        @relation("OrderPrintTaskCompleter")
  orderPrintTaskEvents     OrderPrintTaskEvent[]   @relation("OrderPrintTaskEventActor")
  uploadedPrintEvidences   OrderPrintEvidence[]    @relation("OrderPrintEvidenceUploader")
  installerConfig          InstallerConfig?
  installerCoverageZones   InstallerCoverageZone[]    @relation("InstallerCoverageInstaller")
  assignedOperationalWorkOrders OrderOperationalWorkOrder[] @relation("OperationalWorkOrderAssignee")
  createdOperationalWorkOrders  OrderOperationalWorkOrder[] @relation("OperationalWorkOrderCreator")
  reviewedOperationalWorkOrders OrderOperationalWorkOrder[] @relation("OperationalWorkOrderReviewer")
  checkedOperationalChecklistItems OrderOperationalChecklistItem[] @relation("OperationalChecklistItemChecker")
  uploadedOperationalWorkOrderEvidences OrderOperationalWorkOrderEvidence[] @relation("OperationalWorkOrderEvidenceUploader")
  operationalWorkOrderEvents     OrderOperationalWorkOrderEvent[] @relation("OperationalWorkOrderEventActor")
  operationalWorkOrderReassignmentsFrom OrderOperationalWorkOrderEvent[] @relation("OperationalWorkOrderEventFromInstaller")
  operationalWorkOrderReassignmentsTo   OrderOperationalWorkOrderEvent[] @relation("OperationalWorkOrderEventToInstaller")
  issuedOperationalInstallationReports OrderOperationalInstallationReport[] @relation("OperationalInstallationReportIssuer")
  supersededOperationalInstallationReports OrderOperationalInstallationReport[] @relation("OperationalInstallationReportSuperseder")
  operationsClosedOrders   Order[] @relation("OrderOperationsCloser")
  caseFileArchivedOrders   Order[] @relation("OrderCaseFileArchiver")
  notifications            UserNotification[]
  notificationPreferences  UserNotificationPreference[]

  @@index([userId])
  @@index([isActive])
  @@index([systemRole])
  @@map("user_profile")
}

// ============================================================================
// ORGANIZATION MODULE
// ============================================================================

enum OrganizationType {
  ADVERTISER
  AGENCY
  MEDIA_OWNER
  PLATFORM_ADMIN

  @@map("organization_type")
}

enum LegalEntityType {
  NATURAL_PERSON
  LEGAL_ENTITY

  @@map("legal_entity_type")
}

model Organization {
  id String @id @default(cuid())

  // Basic Information
  name             String
  legalName        String?
  tradeName        String?
  organizationType OrganizationType
  legalEntityType  LegalEntityType

  // Tax/Legal Identifiers
  taxId          String? @unique
  dvCode         String?
  cedula         String? @unique
  passportNumber String?

  // Contact Information
  email    String?
  phone    String?
  whatsapp String?
  website  String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  province     String?
  country      String  @default("PA")
  postalCode   String?

  // Business Details
  description String? @db.Text
  logoUrl     String?
  industry    String?

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  // Audit Fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedBy   String?

  // Relations
  creator           UserProfile?           @relation("OrganizationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members           OrganizationMember[]
  contacts          OrganizationContact[]
  documents         OrganizationDocument[]
  catalogPriceRules CatalogPriceRule[]
  catalogHolds      CatalogHold[]
  campaignRequests  CampaignRequest[]
  orders            Order[]
  notifications     UserNotification[]
  outgoingRelationships OrganizationRelationship[] @relation("OrganizationRelationshipSource")
  incomingRelationships OrganizationRelationship[] @relation("OrganizationRelationshipTarget")
  agencyCatalogHolds CatalogHold[] @relation("CatalogHoldActingAgency")
  agencyCampaignRequests CampaignRequest[] @relation("CampaignRequestActingAgency")
  agencyOrders      Order[] @relation("OrderActingAgency")

  @@index([organizationType])
  @@index([isActive])
  @@index([taxId])
  @@index([cedula])
  @@index([createdById])
  @@map("organization")
}

// ============================================================================
// TEAM MEMBERSHIP MODULE
// ============================================================================

enum OrganizationRole {
  OWNER
  ADMIN
  SALES
  OPERATIONS
  FINANCE
  VIEWER
  CLIENT_VIEWER

  @@map("organization_role")
}

enum OrganizationRelationshipType {
  AGENCY_CLIENT

  @@map("organization_relationship_type")
}

enum OrganizationRelationshipStatus {
  PENDING
  ACTIVE
  INACTIVE

  @@map("organization_relationship_status")
}

model OrganizationMember {
  id String @id @default(cuid())

  organizationId String
  userProfileId  String

  // Role and Permissions
  role        OrganizationRole
  permissions Json?

  // Status
  isActive   Boolean   @default(true)
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?
  expiresAt  DateTime?

  // Audit Fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invitedBy String?

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userProfile  UserProfile  @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userProfileId])
  @@index([organizationId])
  @@index([userProfileId])
  @@index([role])
  @@index([isActive])
  @@map("organization_member")
}

model OrganizationRelationship {
  id String @id @default(cuid())

  sourceOrganizationId String
  targetOrganizationId String

  relationshipType OrganizationRelationshipType
  status           OrganizationRelationshipStatus @default(PENDING)

  canCreateRequests Boolean @default(true)
  canCreateOrders   Boolean @default(true)
  canViewBilling    Boolean @default(false)
  canManageContacts Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedBy   String?

  sourceOrganization Organization @relation("OrganizationRelationshipSource", fields: [sourceOrganizationId], references: [id], onDelete: Cascade)
  targetOrganization Organization @relation("OrganizationRelationshipTarget", fields: [targetOrganizationId], references: [id], onDelete: Cascade)

  @@unique([sourceOrganizationId, targetOrganizationId, relationshipType])
  @@index([sourceOrganizationId])
  @@index([targetOrganizationId])
  @@index([relationshipType])
  @@index([status])
  @@map("organization_relationship")
}

// ============================================================================
// INVENTORY MODULE
// ============================================================================

enum AssetStatus {
  ACTIVE      @map("active")
  INACTIVE    @map("inactive")
  MAINTENANCE @map("maintenance")
  RETIRED     @map("retired")

  @@map("asset_status")
}

enum AssetFaceStatus {
  ACTIVE      @map("active")
  INACTIVE    @map("inactive")
  MAINTENANCE @map("maintenance")
  RETIRED     @map("retired")

  @@map("asset_face_status")
}

enum AssetFaceFacing {
  TRAFFIC          @map("traffic")
  OPPOSITE_TRAFFIC @map("opposite_traffic")

  @@map("asset_face_facing")
}

enum LandTenure {
  SERVIDUMBRE
  PRIVADO
  ESTATAL
  OTRO

  @@map("land_tenure")
}

model Province {
  id   String @id @default(cuid())
  name String @unique

  zones Zone[]

  @@map("province")
}

model Zone {
  id         String  @id @default(cuid())
  name       String
  provinceId String
  imageUrl   String?

  province          Province           @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  assets            Asset[]
  catalogPriceRules CatalogPriceRule[]
  campaignRequests  CampaignRequest[]
  installerCoverageZones InstallerCoverageZone[]
  operationalWorkOrders  OrderOperationalWorkOrder[]

  @@unique([provinceId, name])
  @@index([provinceId])
  @@map("zone")
}

model StructureType {
  id       String  @id @default(cuid())
  name     String  @unique
  imageUrl String?

  assets            Asset[]
  catalogPriceRules CatalogPriceRule[]
  campaignRequests  CampaignRequest[]

  @@map("structure_type")
}

model RoadType {
  id   String @id @default(cuid())
  name String @unique

  assets Asset[]

  @@map("road_type")
}

model Asset {
  id String @id @default(cuid())

  code            String  @unique
  structureTypeId String
  zoneId          String
  roadTypeId      String?

  address      String
  landmark     String?
  municipality String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  landTenure               LandTenure?
  vehicleTrafficMonthly    Int?
  pedestrianTrafficMonthly Int?
  landRentMonthly          Decimal? @db.Decimal(12, 2)
  electricityCostMonthly   Decimal? @db.Decimal(12, 2)
  assetTaxMonthly          Decimal? @db.Decimal(12, 2)

  illuminated     Boolean @default(false)
  digital         Boolean @default(false)
  powered         Boolean @default(false)
  hasPrintService Boolean @default(false)

  status AssetStatus @default(ACTIVE)

  notes String? @db.Text

  installedDate DateTime? @db.Date
  retiredDate   DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  structureType StructureType @relation(fields: [structureTypeId], references: [id], onDelete: Restrict)
  zone          Zone          @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  roadType      RoadType?     @relation(fields: [roadTypeId], references: [id], onDelete: Restrict)

  faces              AssetFace[]
  images             AssetImage[]
  permits            Permit[]
  maintenanceWindows MaintenanceWindow[]

  @@index([structureTypeId])
  @@index([zoneId])
  @@index([roadTypeId])
  @@index([status])
  @@map("asset")
}

model FacePosition {
  id   String @id @default(cuid())
  name String @unique

  faces AssetFace[]

  @@map("face_position")
}

model AssetFace {
  id String @id @default(cuid())

  assetId    String
  code       String
  positionId String?

  width  Decimal @db.Decimal(6, 2)
  height Decimal @db.Decimal(6, 2)

  facing AssetFaceFacing @default(TRAFFIC)

  visibilityNotes String? @db.Text

  status AssetFaceStatus @default(ACTIVE)

  restrictions          String?  @db.Text
  notes                 String?  @db.Text
  productionCostMonthly Decimal? @db.Decimal(12, 2)

  asset    Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  position FacePosition? @relation(fields: [positionId], references: [id], onDelete: Restrict)

  images                     AssetFaceImage[]
  productionSpec             ProductionSpec?
  permits                    Permit[]
  restrictionTags            AssetFaceRestriction[]
  maintenanceWindows         MaintenanceWindow[]
  catalogFace                CatalogFace?
  campaignRequestAssignments CampaignRequestFaceAssignment[]
  orderLineItems             OrderLineItem[]
  operationalWorkOrders      OrderOperationalWorkOrder[]

  @@unique([assetId, code])
  @@index([assetId])
  @@index([positionId])
  @@index([status])
  @@map("asset_face")
}

model AssetImage {
  id        String   @id @default(cuid())
  assetId   String
  image     String
  caption   String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([isPrimary])
  @@map("asset_image")
}

model AssetFaceImage {
  id        String   @id @default(cuid())
  faceId    String
  image     String
  caption   String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  face AssetFace @relation(fields: [faceId], references: [id], onDelete: Cascade)

  @@index([faceId])
  @@index([isPrimary])
  @@map("asset_face_image")
}

model MountingType {
  id   String @id @default(cuid())
  name String @unique

  productionSpecs ProductionSpec[]

  @@map("mounting_type")
}

model ProductionSpec {
  id String @id @default(cuid())

  faceId         String  @unique
  mountingTypeId String?

  material     String?
  bleedCm      Decimal? @db.Decimal(5, 2)
  safeMarginCm Decimal? @db.Decimal(5, 2)

  dpiRecommended Int?
  fileFormat     String?

  installNotes   String? @db.Text
  uninstallNotes String? @db.Text

  face         AssetFace     @relation(fields: [faceId], references: [id], onDelete: Cascade)
  mountingType MountingType? @relation(fields: [mountingTypeId], references: [id], onDelete: Restrict)

  @@index([mountingTypeId])
  @@map("production_spec")
}

model Permit {
  id String @id @default(cuid())

  assetId String
  faceId  String?

  permitNumber String?
  authority    String?
  issuedDate   DateTime? @db.Date
  expiresDate  DateTime? @db.Date
  document     String?
  notes        String?   @db.Text

  asset Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  face  AssetFace? @relation(fields: [faceId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([faceId])
  @@map("permit")
}

model RestrictionTag {
  id    String @id @default(cuid())
  code  String @unique
  label String

  faceRestrictions AssetFaceRestriction[]

  @@map("restriction_tag")
}

model AssetFaceRestriction {
  id     String @id @default(cuid())
  faceId String
  tagId  String

  face AssetFace      @relation(fields: [faceId], references: [id], onDelete: Cascade)
  tag  RestrictionTag @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@unique([faceId, tagId])
  @@index([faceId])
  @@index([tagId])
  @@map("asset_face_restriction")
}

model MaintenanceWindow {
  id String @id @default(cuid())

  assetId String
  faceId  String?

  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String
  notes     String?  @db.Text

  asset Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  face  AssetFace? @relation(fields: [faceId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([faceId])
  @@index([startDate])
  @@map("maintenance_window")
}

// ============================================================================
// CATALOG MODULE (Face-based)
// ============================================================================

enum CatalogPromoType {
  PERCENT @map("percent")
  FIXED   @map("fixed")

  @@map("catalog_promo_type")
}

enum CatalogHoldStatus {
  ACTIVE    @map("active")
  EXPIRED   @map("expired")
  RELEASED  @map("released")
  CONVERTED @map("converted")

  @@map("catalog_hold_status")
}

enum CampaignRequestStatus {
  NEW                 @map("new")
  IN_REVIEW           @map("in_review")
  QUOTATION_GENERATED @map("quotation_generated")
  PROPOSAL_SENT       @map("proposal_sent")
  CONFIRMED           @map("confirmed")
  REJECTED            @map("rejected")

  @@map("campaign_request_status")
}

model CatalogFace {
  id String @id @default(cuid())

  faceId          String  @unique
  title           String?
  summary         String?
  highlight       String?
  primaryImageUrl String?
  isPublished     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  face       AssetFace          @relation(fields: [faceId], references: [id], onDelete: Cascade)
  priceRules CatalogPriceRule[]
  holds      CatalogHold[]

  @@index([isPublished])
  @@map("catalog_face")
}

model CatalogPriceRule {
  id String @id @default(cuid())

  faceId          String?
  structureTypeId String?
  zoneId          String?
  organizationId  String?

  priceDaily Decimal   @db.Decimal(12, 2)
  currency   String    @default("USD")
  startDate  DateTime  @default(now())
  endDate    DateTime?
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())

  face          CatalogFace?   @relation(fields: [faceId], references: [faceId], onDelete: Cascade)
  structureType StructureType? @relation(fields: [structureTypeId], references: [id], onDelete: Restrict)
  zone          Zone?          @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([faceId])
  @@index([structureTypeId])
  @@index([zoneId])
  @@index([organizationId])
  @@index([isActive])
  @@index([startDate])
  @@map("catalog_price_rule")
}

model CatalogPromo {
  id String @id @default(cuid())

  name      String
  type      CatalogPromoType
  value     Decimal          @db.Decimal(12, 2)
  startDate DateTime         @default(now())
  endDate   DateTime?
  isActive  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([startDate])
  @@map("catalog_promo")
}

model CatalogHold {
  id String @id @default(cuid())

  faceId         String
  organizationId String?
  actingAgencyOrganizationId String?
  createdById    String?

  status     CatalogHoldStatus @default(ACTIVE)
  expiresAt  DateTime
  releasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  face         CatalogFace   @relation(fields: [faceId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actingAgencyOrganization Organization? @relation("CatalogHoldActingAgency", fields: [actingAgencyOrganizationId], references: [id], onDelete: SetNull)
  createdBy    UserProfile?  @relation("CatalogHoldCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([faceId])
  @@index([organizationId])
  @@index([actingAgencyOrganizationId])
  @@index([status])
  @@index([expiresAt])
  @@map("catalog_hold")
}

model CampaignRequest {
  id String @id @default(cuid())

  query           String?
  zoneId          String?
  structureTypeId String?
  quantity        Int
  fromDate        DateTime? @db.Date
  toDate          DateTime? @db.Date
  notes           String?   @db.Text

  contactName  String?
  contactEmail String?
  contactPhone String?

  organizationId String?
  actingAgencyOrganizationId String?
  createdById    String?

  status       CampaignRequestStatus @default(NEW)
  resolvedAt   DateTime?
  resolvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zone          Zone?                           @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  structureType StructureType?                  @relation(fields: [structureTypeId], references: [id], onDelete: SetNull)
  organization  Organization?                   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actingAgencyOrganization Organization?        @relation("CampaignRequestActingAgency", fields: [actingAgencyOrganizationId], references: [id], onDelete: SetNull)
  createdBy     UserProfile?                    @relation("CampaignRequestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  resolvedBy    UserProfile?                    @relation("CampaignRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  assignments   CampaignRequestFaceAssignment[]
  services      CampaignRequestService[]
  order         Order?

  @@index([status])
  @@index([zoneId])
  @@index([structureTypeId])
  @@index([organizationId])
  @@index([actingAgencyOrganizationId])
  @@index([createdById])
  @@index([createdAt])
  @@map("campaign_request")
}

model CampaignRequestFaceAssignment {
  id String @id @default(cuid())

  requestId String
  faceId    String

  createdAt DateTime @default(now())

  request CampaignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  face    AssetFace       @relation(fields: [faceId], references: [id], onDelete: Cascade)

  @@unique([requestId, faceId])
  @@index([requestId])
  @@index([faceId])
  @@map("campaign_request_face_assignment")
}

model CampaignService {
  id String @id @default(cuid())

  code        String  @unique
  name        String
  description String? @db.Text
  basePrice   Decimal @default(0.0) @db.Decimal(12, 2)
  currency    String  @default("USD")
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestServices CampaignRequestService[]
  orderItems      OrderServiceItem[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("campaign_service")
}

model CampaignRequestService {
  id String @id @default(cuid())

  requestId String
  serviceId String

  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)
  notes     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request    CampaignRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  service    CampaignService    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  orderItems OrderServiceItem[]

  @@unique([requestId, serviceId])
  @@index([requestId])
  @@index([serviceId])
  @@map("campaign_request_service")
}

// ============================================================================
// ORDERS & QUOTATIONS MODULE
// ============================================================================

enum OrderStatus {
  DRAFT           @map("draft")
  QUOTATION_SENT  @map("quotation_sent")
  CLIENT_APPROVED @map("client_approved")
  CONFIRMED       @map("confirmed")
  CANCELLED       @map("cancelled")

  @@map("order_status")
}

enum SalesReviewStatus {
  NOT_STARTED
  PENDING_REVIEW
  APPROVED
  CHANGES_REQUESTED

  @@map("sales_review_status")
}

enum PurchaseOrderReviewStatus {
  PENDING_REVIEW
  APPROVED
  CHANGES_REQUESTED

  @@map("purchase_order_review_status")
}

enum SalesReviewEventType {
  REVIEW_REQUIRED
  DOCUMENT_APPROVED
  DOCUMENT_CHANGES_REQUESTED
  ORDER_APPROVED
  ORDER_CHANGES_REQUESTED
  CRITICAL_CHANGE
