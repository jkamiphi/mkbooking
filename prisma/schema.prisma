model Order {
  id   String @id @default(cuid())
  code String @unique @default(dbgenerated("concat('ORD-', lpad(cast(nextval('order_code_seq') as text), 6, '0'))"))

  // Link to request
  campaignRequestId String? @unique

  // Information
  organizationId String?
  actingAgencyOrganizationId String?
  createdById    String?
  clientName     String?
  clientEmail    String?

  // Financials
  currency String  @default("USD")
  subTotal Decimal @default(0.0) @db.Decimal(12, 2)
  tax      Decimal @default(0.0) @db.Decimal(12, 2)
  total    Decimal @default(0.0) @db.Decimal(12, 2)

  // Dates
  fromDate DateTime? @db.Date
  toDate   DateTime? @db.Date

  notes  String?     @db.Text
  status OrderStatus @default(DRAFT)

  // Approvals
  clientApprovedAt     DateTime?
  companyConfirmedAt   DateTime?
  companyConfirmedById String?
  salesReviewStatus    SalesReviewStatus @default(NOT_STARTED)
  salesReviewUpdatedAt DateTime?
  salesReviewById      String?
  salesReviewNotes     String?           @db.Text
  salesReviewVersion   Int               @default(0)
  operationsClosedAt   DateTime?
  operationsClosedById String?
  caseFileArchivedAt   DateTime?
  caseFileArchivedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaignRequest   CampaignRequest?        @relation(fields: [campaignRequestId], references: [id], onDelete: SetNull)
  organization      Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actingAgencyOrganization Organization?    @relation("OrderActingAgency", fields: [actingAgencyOrganizationId], references: [id], onDelete: SetNull)
  createdBy         UserProfile?            @relation("OrderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  companyConfirmBy  UserProfile?            @relation("OrderConfirmer", fields: [companyConfirmedById], references: [id], onDelete: SetNull)
  salesReviewBy     UserProfile?            @relation("OrderSalesReviewer", fields: [salesReviewById], references: [id], onDelete: SetNull)
  operationsClosedBy UserProfile?           @relation("OrderOperationsCloser", fields: [operationsClosedById], references: [id], onDelete: SetNull)
  caseFileArchivedBy UserProfile?           @relation("OrderCaseFileArchiver", fields: [caseFileArchivedById], references: [id], onDelete: SetNull)
  lineItems         OrderLineItem[]
  serviceItems      OrderServiceItem[]
  creatives         OrderCreative[]
  purchaseOrders    OrderPurchaseOrder[]
  salesReviewEvents OrderSalesReviewEvent[]
  designTask        OrderDesignTask?
  printTask         OrderPrintTask?
  operationalWorkOrders OrderOperationalWorkOrder[]
  operationalInstallationReports OrderOperationalInstallationReport[]
  notifications     UserNotification[]

  @@index([status])
  @@index([organizationId])
  @@index([actingAgencyOrganizationId])
  @@index([createdById])
  @@index([campaignRequestId])
  @@index([salesReviewStatus])
  @@index([salesReviewById])
  @@index([operationsClosedById])
  @@index([caseFileArchivedById])
  @@map("order")
}

model OrderLineItem {
